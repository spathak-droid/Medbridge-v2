# LLM provider
OPENAI_API_KEY=your-openai-api-key-here

# Database — PostgreSQL recommended for production (Railway, Supabase, etc.)
# For local dev: sqlite+aiosqlite:///./medbridge.db
# For production: postgresql://user:pass@host:port/dbname
DATABASE_URL=postgresql://user:password@host:port/dbname

# Application
APP_ENV=development
DEBUG=true

# Langfuse observability
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# OpenRouter LLM provider
OPEN_ROUTER_API_KEY=your-openrouter-api-key-here
OPEN_ROUTER_MODEL=anthropic/claude-haiku-4.5

# Firebase client-side config
FIREBASE_API_KEY="your-firebase-api-key-here"
FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
FIREBASE_MESSAGING_SENDER_ID="your-firebase-messaging-sender-id"
FIREBASE_APP_ID="your-firebase-app-id"

# Firebase Admin SDK (for server-side token verification)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# CORS — comma-separated allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis (for rate limiting — optional, falls back to in-memory)
REDIS_URL=redis://host:port

# Rate limiting
RATE_LIMIT_PER_MINUTE=300

# HIPAA audit log file path
AUDIT_LOG_PATH=audit.log

# Resend email API (for reminder/check-in/digest notifications)
RESEND_API_KEY=your-resend-api-key-here
RESEND_EMAIL=your-email@example.com
